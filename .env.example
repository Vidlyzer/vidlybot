# Token Bot Discord (Dapatkan dari Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# URL Koneksi Database PostgreSQL
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:password@localhost:5432/vidlyzer

# Catatan: 
# ID Client dan ID Owner diatur di dalam file src/core/config.ts
# karena dianggap sebagai data non-sensitif.
